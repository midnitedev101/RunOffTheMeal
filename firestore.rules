rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email.matches('.*@runoffthemeal.com');
    }

    function isValidRecipe(data) {
      return data.title is string
        && data.title.size() <= 120
        && data.description is string
        && data.description.size() <= 2000
        && data.instructions is string
        && data.instructions.size() <= 10000
        && data.ingredients is list
        && data.ingredients.size() >= 1
        && data.rating is number
        && data.ratingCount is number;
    }

    match /recipes/{recipeId} {
      allow read: if true;
      allow create: if request.resource.data.status == 'user'
        || (request.resource.data.status == 'admin' && isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /dailyRecipes/{date} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
